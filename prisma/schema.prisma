generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          String         @default("USER") // "USER" or "ADMIN"
  avatar        String?
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  reviews       Review[]
  wishlist      Wishlist[]
  notifications Notification[]
}

model Car {
  id           String     @id @default(uuid())
  name         String
  brand        String
  type         String     // "Luxury", "SUV", "Electric", "Sedan", etc.
  pricePerDay  Float
  transmission String     // "Automatic", "Manual"
  fuel         String     // "Petrol", "Diesel", "Electric", "Hybrid"
  seats        Int
  slug         String     @unique
  description  String
  features     String     // Stored as JSON string list, e.g. '["GPS", "AC", "Bluetooth"]'
  availability Boolean    @default(true)
  rating       Float      @default(5.0)
  images       CarImage[]
  bookings     Booking[]
  reviews      Review[]
  wishlist     Wishlist[]
}

model CarImage {
  id    String @id @default(uuid())
  carId String
  url   String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Booking {
  id             String    @id @default(uuid())
  userId         String
  carId          String
  pickupLocation String
  dropoffLocation String
  pickupDate     DateTime
  dropoffDate    DateTime
  totalPrice     Float
  status         String    @default("PENDING") // "PENDING", "CONFIRMED", "CANCELLED"
  couponCode     String?
  discount       Float     @default(0.0)
  invoiceUrl     String?
  paymentStatus  String    @default("UNPAID") // "PAID", "UNPAID"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  car            Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  payments       Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String
  amount        Float
  provider      String   // "CARD", "MOCK"
  status        String   // "SUCCESS", "FAILED"
  transactionId String   @unique
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  carId     String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Int
  active          Boolean  @default(true)
  expiryDate      DateTime
}

model Location {
  id        String @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
}

model Wishlist {
  id     String @id @default(uuid())
  userId String
  carId  String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  car    Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
